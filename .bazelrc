# Check direct module dependencies are up-to-date
common --check_direct_dependencies=error

# Ensure that tags applied in your BUILD file, like tags = ["no-remote"] get propagated to actions
# created by the rule. See: https://github.com/bazelbuild/bazel/issues/7766
common --incompatible_allow_tags_propagation

# Don't let environment variables sneak into the build.
build --incompatible_strict_action_env

# Don't implicitly create __init__.py files.
build --incompatible_default_to_explicit_init_py

# --- Remote cache (default: on for all commands, all hosts) ---
# The API key is not stored here. Add it to .bazelrc.user (gitignored):
#   common --remote_header=x-buildbuddy-api-key=YOUR_KEY
common --remote_cache=grpcs://remote.buildbuddy.io
common --remote_timeout=10m
build --remote_cache_compression=true

# Disable network access for sandboxed actions by default.
build --sandbox_default_allow_network=false

# Show output of failing tests inline instead of requiring `cat bazel-testlogs/...`
test --test_output=errors
test --test_verbose_timeout_warnings
# On any build failure, print the full command line that failed
build --verbose_failures

# Allow the Bazel server to check directory sources for changes. Ensures that the Bazel server
# notices when a directory changes, if you have a directory listed in the srcs of some target.
# Docs: https://bazel.build/reference/command-line-reference#flag--host_jvm_args
startup --host_jvm_args=-DBAZEL_TRACK_SOURCE_DIRECTORIES=1

# Allow exclusive tests to run in the sandbox. Fixes a bug where Bazel doesn't enable sandboxing for
# tests with `tags=["exclusive"]`.
# Docs: https://bazel.build/reference/command-line-reference#flag--incompatible_exclusive_test_sandboxed
common --incompatible_exclusive_test_sandboxed

# Set default value of `allow_empty` to `False` in `glob()`. This prevents a common mistake when
# attempting to use `glob()` to match files in a subdirectory that is opaque to the current package
# because it contains a BUILD file. See https://github.com/bazelbuild/bazel/issues/8195.
# Docs: https://bazel.build/reference/command-line-reference#flag--incompatible_disallow_empty_glob
common --incompatible_disallow_empty_glob

coverage --combined_report=lcov
# Required so coverage files are returned on remote-cache hits (not just on misses).
coverage --experimental_fetch_all_coverage_outputs

# Force CGO_ENABLED=0 for every go_binary / go_library / go_test in the build. This is the
# pivot point that makes "build any target from any host" simple: Go's own toolchain ships
# every GOOS/GOARCH pair, so no C toolchain or sysroot is needed for cross-compile.
#
# This is a deliberate policy choice for the monorepo — see docs/future-considerations.md
# ("Introducing cgo or Python C-Extensions") for the implications of changing it. CI enforces
# the policy via meta/scripts/check_no_cgo.py.
build --@rules_go//go/config:pure


# --- --config=remote_bb: offload builds/tests to BuildBuddy's remote executors (no BES). ---
# Naming convention: remote-executor configs are suffixed with the backend (`_bb` = BuildBuddy).
# Additional remote backends (e.g. a future `:remote_rpi` for a Raspberry Pi CM5 cluster on
# linux_arm64) would follow the same pattern and set their own --platforms.
common:remote_bb --remote_executor=grpcs://remote.buildbuddy.io
build:remote_bb --remote_local_fallback
build:remote_bb --remote_download_outputs=toplevel

# Without this flag, a mid-build eviction fails the whole invocation; with it, Bazel retries.
build:remote_bb --experimental_remote_cache_eviction_retries=5

# The report-merge step can't run remotely — it needs every per-test file materialised locally.
coverage:remote_bb --strategy=CoverageReport=local

# Claude thinks that the default for local builds is roughly <CPU count>, and for remote builds is
# ~200. If that's true, the value I was going to set is lower than the default.
# TEND(optimization): Check the BuildBuddy invocation timeline occasionally to look for underutilization.
# Gaps where few actions are in flight can indicate that this value should be raised.
# common:remote_bb --jobs=100


# --- --config=ci: Expected to run from GitHub Actions. Starts with :remote_bb and adds BES reporting. ---
common:ci --config=remote_bb
build:ci --bes_backend=grpcs://remote.buildbuddy.io
build:ci --bes_results_url=https://app.buildbuddy.io/invocation/

# Only send BEP events for outputs that actually made it to the remote cache.
# Keeps output from locally-executed / no-cache / no-remote actions out of BuildBuddy.
build:ci --remote_build_event_upload=minimal
# Logs which bazelrc flags are active - invaluable for debugging CI weirdness
common:ci --announce_rc
# Adds timestamps to action output; helpful when parsing slow builds
build:ci --show_timestamps
# GitHub Actions renders ANSI; force color since stdout isn't a TTY
common:ci --color=yes
# Tell us _everything_
test:ci --test_output=all


# --- --config=local: disable all remote features (offline / debugging). ---
common:local --remote_cache=
common:local --remote_executor=
build:local --bes_backend=
build:local --bes_results_url=


# --- Target platform shortcuts ---
# BuildBuddy serves linux_x86_64 and linux_arm64 executors. For each linux config we
# register both the matching BB exec platform AND the matching BB cc toolchain so
# toolchain resolution can dispatch actions (including Bazel-internal cpp tools like
# ijar) to the correct arch's executor pool with a compatible cpp toolchain. We do
# this per-config rather than globally in MODULE.bazel: a global registration would
# expose BB's linux platforms / toolchains on the darwin runner too, where ijar would
# pick a linux exec platform and then fail to find a compatible cc toolchain (the
# host only has its auto-detected darwin cc toolchain).
#
# Without --extra_toolchains, the BB cc toolchains aren't considered during cpp
# toolchain resolution at all (BB's transitive register_toolchains in their bzlmod
# MODULE.bazel doesn't surface them in our build). The linux_x86_64 case happened
# to work without this flag because the Linux runner's auto-detected local_config_cc
# satisfies the BB linux_x86_64 exec platform's constraints; linux_arm64 doesn't
# get the same accident.
#
# darwin_arm64 still has no remote executor, so its per-platform config clears
# --remote_executor (otherwise BB would accept the action and fail it with "Exec format
# error" on a Linux executor rather than the runner falling back locally). The remote
# *cache* is unaffected; only execution routing changes.
#
# Devs on a non-linux host (e.g. macOS) who want `bazel test --config=linux_*` to
# actually run the linux test binaries can opt in by adding the following to their
# .bazelrc.user (which already holds the BB API key):
#
#     test:linux_x86_64 --config=remote_bb
#     test:linux_arm64  --config=remote_bb
#
# Builds work locally without this (pure-Go cross-compile); only test *execution*
# needs an arch-matched runtime. We don't enable this in the committed .bazelrc
# because it'd silently couple "target linux" with "use BB" for everyone, including
# devs on a native linux host who don't need or want remote execution.
build:linux_x86_64 --platforms=//platforms:linux_x86_64
build:linux_x86_64 --extra_execution_platforms=@toolchains_buildbuddy//platforms:linux_x86_64
build:linux_x86_64 --extra_toolchains=@toolchains_buildbuddy//toolchains/cc:ubuntu_gcc_x86_64

build:linux_arm64 --platforms=//platforms:linux_arm64
build:linux_arm64 --extra_execution_platforms=@toolchains_buildbuddy//platforms:linux_arm64
build:linux_arm64 --extra_toolchains=@toolchains_buildbuddy//toolchains/cc:ubuntu_gcc_arm64

build:darwin_arm64 --platforms=//platforms:darwin_arm64
build:darwin_arm64 --remote_executor=

# Allow users to specify personal .bazelrc.user files.
try-import %workspace%/.bazelrc.user
