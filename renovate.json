{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [ "/^MODULE\\.bazel$/" ],
      "matchStrings": [ "go_sdk\\.download\\(\\s*version\\s*=\\s*\"(?<currentValue>[^\"]+)\"" ],
      "datasourceTemplate": "golang-version",
      "depNameTemplate": "go"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [ "/^MODULE\\.bazel$/" ],
      "matchStrings": [ "python\\.toolchain\\(\\s*python_version\\s*=\\s*\"(?<currentValue>[^\"]+)\"" ],
      "datasourceTemplate": "python-version",
      "depNameTemplate": "python"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^go\\.work$/",
        "/(^|/)go\\.mod$/"
      ],
      "matchStrings": [ "^go (?<currentValue>\\d+\\.\\d+(?:\\.\\d+)?)" ],
      "datasourceTemplate": "golang-version",
      "depNameTemplate": "go"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [ "/(^|/)BUILD\\.bazel$/" ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s*\\n\\s*\"container-image\"\\s*:\\s*\"docker://[^\"@]+:(?<currentValue>[^\"@]+)@sha256:(?<currentDigest>[a-f0-9]+)\""
      ],
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [ "bazel-module" ],
      "groupName": "Bazel toolchains and rulesets"
    },
    {
      "matchManagers": [ "gomod" ],
      "groupName": "Go dependencies"
    },
    {
      "matchManagers": [ "github-actions" ],
      "groupName": "GitHub Actions"
    },
    {
      "matchManagers": [ "custom.regex" ],
      "matchDepNames": [ "go", "python" ],
      "groupName": "Language toolchain SDKs"
    },
    {
      "matchManagers": [ "custom.regex" ],
      "matchDatasources": [ "docker" ],
      "groupName": "Container images"
    }
  ]
}
