{
  "version": "2.0.0",

  "// Repo-health checks": "These scripts used to run in pre-commit and were briefly run silently via emeraldwalk.runonsave. Defined as tasks with problem matchers so failures surface as squiggles + Problems-panel entries instead of disappearing into an output channel. Triggered on save by gruntfuggly.triggertaskonsave (see settings.json).",

  "// Diagnostic format contract": "Each script emits `path:line: message` per failure (see check_go_modules.py / check_go_work.py for how anchor lines are chosen). The matcher pattern below parses that into VS Code diagnostics. The matcher's `owner` namespaces the diagnostics so a re-run with no findings clears the previous run's squiggles.",

  "// Bazel build/test": "Marked as default for their respective groups so Cmd+Shift+B / Run Test Task pick them up. Surfaced in the Task Manager sidebar via taskManager.favorites (settings.json).",

  "tasks": [
    {
      "label": "check: go modules",
      "type": "shell",
      "command": "python3",
      "args": ["${workspaceFolder}/meta/scripts/check_go_modules.py"],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true,
        "revealProblems": "onProblem"
      },
      "problemMatcher": {
        "owner": "check-go-modules",
        "source": "check_go_modules",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "severity": "error",
        "pattern": {
          "regexp": "^(\\S+):(\\d+):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "message": 3
        }
      }
    },
    {
      "label": "check: go work",
      "type": "shell",
      "command": "python3",
      "args": ["${workspaceFolder}/meta/scripts/check_go_work.py"],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true,
        "revealProblems": "onProblem"
      },
      "problemMatcher": {
        "owner": "check-go-work",
        "source": "check_go_work",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "severity": "error",
        "pattern": {
          "regexp": "^(\\S+):(\\d+):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "message": 3
        }
      }
    },
    {
      "label": "Bazel Build all",
      "detail": "bazel build //...",
      "type": "process",
      "command": "bazel",
      "args": ["build", "//..."],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Bazel Test all",
      "detail": "bazel test //...",
      "type": "process",
      "command": "bazel",
      "args": ["test", "//..."],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
